# ============================================
# VARIÁVEIS DE AMBIENTE — Planner TDAH Produtivo
# ============================================
# Copie este arquivo como .env e preencha os valores

# --- Asaas ---
# Sua API Key do Asaas (obrigatória)
# Sandbox: use a chave do painel sandbox.asaas.com
# Produção: use a chave do painel www.asaas.com
ASAAS_API_KEY=sua_api_key_aqui

# Ambiente: "sandbox" ou "production"
ASAAS_ENVIRONMENT=sandbox

# Token do webhook (opcional — configure no painel Asaas > Integrações > Webhooks)
ASAAS_WEBHOOK_TOKEN=

# --- Servidor ---
# Chave secreta para sessões Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-segura-aleatoria

# --- Produto (opcional — valores padrão no config.py) ---
# PRODUCT_PRICE=29.90
# PRODUCT_NAME=Planner TDAH Produtivo

# --- Deploy ---
# PORT=5000
# HOST=0.0.0.0
# DEBUG=false
